# =============================
# Backend - Spring Boot
# =============================

# Server
APP_NAME=garbage-reporting-service
SERVER_PORT=8080
SERVER_CONTEXT_PATH=/

# MongoDB
MONGODB_URI=mongodb://localhost:27017/garbage_reporting

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TIMEOUT=2s

# RabbitMQ
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest

# Messaging topology
REPORT_PROCESSING_QUEUE=report.processing.queue
REPORT_PROCESSING_EXCHANGE=report.processing.exchange
REPORT_PROCESSING_ROUTING_KEY=report.processing.created
REPORT_PROCESSING_DLQ=report.processing.dlq
REPORT_PROCESSING_DLX=report.processing.dlx
REPORT_PROCESSING_DLQ_ROUTING_KEY=report.processing.failed

# Cache
REPORTS_TODAY_TTL_MINUTES=10
ROUTE_OPTIMIZATION_TTL_MINUTES=20
CACHE_TTL=10m

# Routing
ROUTING_ENABLED=true
ROUTING_PROVIDER=osrm
OSRM_BASE_URL=https://router.project-osrm.org
ROUTING_PROFILE=driving

# Catalogo local de clasificacion exacta por hash (SHA-256)
TRASH_CATALOG_DIR=storage/catalog/basura
NON_TRASH_CATALOG_DIR=storage/catalog/no-basura

# Storage
IMAGE_STORAGE_DIR=uploads
MAX_FILE_SIZE=10MB
MAX_REQUEST_SIZE=10MB

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173
CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=*
CORS_ALLOW_CREDENTIALS=false

# Auth / JWT
JWT_SECRET=change-this-jwt-secret-for-demo-at-least-32-chars
JWT_EXPIRATION_MINUTES=120
VERIFY_TOKEN_EXP_HOURS=24

# Seed admin user
ADMIN_FIRST_NAME=Admin
ADMIN_LAST_NAME=Demo
ADMIN_EMAIL=admin@ecoruta.local
ADMIN_PASSWORD=Admin12345!

# Verification email (mock-friendly)
MAIL_MOCK_ENABLED=false
MAIL_FROM=no-reply@ecoruta.local
EMAIL_VERIFY_BASE_URL=http://localhost:5173/verify-email/confirm
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_SMTP_AUTH=false
MAIL_SMTP_STARTTLS_ENABLE=false

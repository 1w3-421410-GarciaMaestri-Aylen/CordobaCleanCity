5rem;padding:10px 12px;text-align:center;font-weight:600}.location-map-wrap{flex:1;min-height:0}.location-map{width:100%;height:100%;min-height:260px;border-radius:var(--radius-lg);border:1px solid #bed7db;box-shadow:var(--shadow-xs);overflow:hidden}.admin-panel-backdrop{position:fixed;top:0;right:0;bottom:0;left:0;z-index:1500;background:#091c2766;display:flex;align-items:flex-end;justify-content:center;padding:12px}.admin-panel{width:min(580px,100%);border-radius:22px 22px 14px 14px;border:1px solid #cadde2;background:#fffffff2;box-shadow:var(--shadow-soft);padding:14px;display:flex;flex-direction:column;gap:12px;max-height:min(88vh,760px);overflow-y:auto}.admin-panel-header{display:flex;justify-content:space-between;align-items:flex-start;gap:10px}.admin-panel-header h2{margin:0;color:#143544;font-size:1.08rem}.admin-panel-header p{margin:4px 0 0;color:#607c86;font-size:.84rem}.admin-metrics-grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:8px}.admin-metric-item{border-radius:11px;border:1px solid #d4e2e4;background:#f6fbfb;padding:10px 9px;display:flex;flex-direction:column;gap:6px}.admin-metric-item span{color:#5b757f;font-size:.74rem}.admin-metric-item strong{color:#163f50;font-size:.98rem}.admin-actions-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:10px}@media (min-width: 520px){.app-root{padding:20px 20px 24px}.upload-card{padding:16px}.coordinate-grid{grid-template-columns:repeat(2,minmax(0,1fr))}.auth-root{padding:24px}.auth-card{padding:20px}.quick-report-card{padding:16px}.location-grid{grid-template-columns:repeat(2,minmax(0,1fr))}.admin-panel-backdrop{align-items:center}.admin-panel{border-radius:22px}}@media (min-width: 768px){.mobile-shell{max-width:620px}.map-overlay-backdrop{padding:16px;align-items:center;justify-content:center}.map-overlay{width:min(980px,100%);height:min(92vh,760px);border-radius:22px;border:1px solid #c8dce0;box-shadow:var(--shadow-soft);padding:14px}.qr-modal-backdrop{align-items:center;padding:20px}.qr-modal{border-radius:20px;max-width:380px}.quick-report-shell{max-width:520px}.location-overlay-backdrop{padding:16px;align-items:center;justify-content:center}.location-overlay{width:min(840px,100%);height:min(92vh,760px);border-radius:22px;border:1px solid #c8dce0;box-shadow:var(--shadow-soft);padding:14px}}
